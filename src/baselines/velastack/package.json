{
	"name": "velastack",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vela dev",
		"build": "vela build",
		"preview": "vela preview",
		"sync": "svelte-kit sync",
		"prepare": "svelte-kit sync && vela sync || echo ''",
		"test:server": "vela test:server",
		"check": "svelte-kit sync && vela sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && vela sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.1.14",
		"@types/supertest": "^6.0.3",
		"@velastack/pocketbase": "^0.0.43",
		"clsx": "^2.1.1",
		"formsnap": "^2.0.1",
		"mode-watcher": "^1.1.0",
		"pocketbase-svelte": "^0.26.4",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"shadcn-svelte": "^1.2.7",
		"supertest": "^7.1.4",
		"svelte": "^5.41.0",
		"svelte-check": "^4.0.0",
		"svelte-meta-tags": "^4.5.0",
		"svelte-sonner": "^1.0.5",
		"sveltekit-flash-message": "^2.4.6",
		"sveltekit-superforms": "^2.27.2",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.14",
		"tw-animate-css": "^1.3.5",
		"typescript": "^5.0.0",
		"vite": "^7.3.1",
		"vitest": "^3.2.3",
		"zod": "^4.1.11"
	}
}
