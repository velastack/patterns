{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*", "vite.config.ts", "scripts/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/baselines/**",
    "**/fixtures/**",
    "**/preview-modifies/**",
    "**/creates/**",
    "**/creates-app-mode/**",
    "**/creates-with-negotiation/**",
    "**/creates-with-blog/**"
  ]
}
