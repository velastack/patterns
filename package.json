{
  "name": "@velastack/patterns",
  "version": "0.0.48",
  "description": "Registry of VelaStack patterns: generators and modifications applied to SvelteKit projects by the VelaStack CLI.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velastack/patterns.git"
  },
  "homepage": "https://github.com/velastack/patterns#readme",
  "bugs": {
    "url": "https://github.com/velastack/patterns/issues"
  },
  "keywords": [
    "velastack",
    "sveltekit",
    "patterns",
    "generators",
    "scaffolding",
    "pocketbase"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "demo": "vite-node scripts/demo.ts --",
    "format": "prettier --write .",
    "lint": "npm run lint:ts && npm run lint:format",
    "lint:ts": "tsc --noEmit",
    "lint:format": "prettier --check .",
    "test": "vitest run --exclude **/integration.test.ts",
    "test:watch": "vitest --watch --exclude **/integration.test.ts",
    "test:integration": "vitest run **/integration.test.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1"
  },
  "peerDependencies": {
    "@velastack/pocketbase": "^0.0.51",
    "cross-spawn": "^7.0.6",
    "magic-string": "^0.30.21",
    "package-manager-detector": "^1.6.0",
    "pocketbase": "^0.26.8",
    "stripe": "^19.0.0",
    "svelte": "^5.55.4",
    "ts-morph": "^28.0.0"
  },
  "peerDependenciesMeta": {
    "@velastack/pocketbase": {
      "optional": true
    },
    "cross-spawn": {
      "optional": true
    },
    "magic-string": {
      "optional": true
    },
    "package-manager-detector": {
      "optional": true
    },
    "pocketbase": {
      "optional": true
    },
    "stripe": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "ts-morph": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/pluralize": "^0.0.33",
    "@velastack/pocketbase": "^0.0.51",
    "change-case": "^5.4.4",
    "cross-spawn": "^7.0.6",
    "dedent": "^1.7.2",
    "magic-string": "^0.30.21",
    "package-manager-detector": "^1.6.0",
    "pluralize": "^8.0.0",
    "pocketbase": "^0.26.8",
    "stripe": "^19.3.0",
    "svelte": "^5.55.4",
    "ts-morph": "^28.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
